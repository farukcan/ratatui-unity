# ── Rust ──────────────────────────────────────────────────────────────────────
/target/

# ── Unity ─────────────────────────────────────────────────────────────────────
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# Unity-generated metadata (committed: .meta files alongside assets)
# Do NOT ignore *.meta — Unity requires them

# ── Native plugin binaries (generated by build_all.sh / CI) ──────────────────
Packages/com.farukcan.ratatui.unity/Plugins/Windows/**/*.dll
Packages/com.farukcan.ratatui.unity/Plugins/macOS/*.bundle
Packages/com.farukcan.ratatui.unity/Plugins/Linux/**/*.so
Packages/com.farukcan.ratatui.unity/Plugins/iOS/*.xcframework/
Packages/com.farukcan.ratatui.unity/Plugins/Android/**/*.so
Packages/com.farukcan.ratatui.unity/Plugins/WebGL/*.a

# Keep .jslib and .meta files tracked
!Packages/com.farukcan.ratatui.unity/Plugins/WebGL/*.jslib

# ── Unity Package Samples (tilde suffix ignored by global gitignore *~) ───────
!Packages/com.farukcan.ratatui.unity/Samples~/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
